# Copy to .env only when a local authenticated MCP run is required.
# Never commit a real token. Enable auth separately in config/mcp.yaml.
MARL_MCP_TOKEN=replace-with-a-long-random-local-token

# Private report identity. Keep real values only in the ignored .env file.
MARL_STUDENT_NAME=replace-with-your-name
MARL_STUDENT_ID=replace-with-your-student-id
